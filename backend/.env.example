# Camera source: "real" (OpenCV VideoCapture index) or "mock" (cycles sample images)
CAMERA_MODE=mock
CAMERA_INDEX=0
# Mock image folder (used when CAMERA_MODE=mock)
MOCK_IMAGES_DIR=./mock_caps
# Circular ROI (fraction of frame height)
ROI_RADIUS_FRACTION=0.25
# Minimum seconds between accepted detections (debounce)
DETECTION_DEBOUNCE_SEC=1.5
# SQLite path
DB_PATH=./data/sorter.db
# LINE webhook (stub -- leave empty to just log). Swap to LINE Messaging API push.
LINE_WEBHOOK_URL=
LINE_CHANNEL_TOKEN=
LINE_TARGET_ID=
# CORS origin for the frontend dev server
FRONTEND_ORIGIN=http://localhost:5173
